        </iframe>

        <div id="video-links">
            <a href="https://www.youtube.com/embed/uKD9C3b8M2A" target="ifr-video">Prezentare Motor</a>
            <a href="https://www.youtube.com/embed/ZFEzMKYjShc?si=XIonvTIvyRRe40wK" target="ifr-video">Aerodinamică 2026</a>
            <a href="https://www.youtube.com/embed/mdnF9R-Bzpg?si=_ifU8B9puv3bzLmm" target="ifr-video">Video Default</a>
        </div>
    </div>
</section>



        <!--  task 13 link uri plus footer la final -->
        <section id="resurse-f1">
            <h2>Resurse și Link-uri Utile</h2>
            <ul>
                <li>Vezi noutăți pe <a href="https://www.formula1.com" target="_blank">Site-ul Oficial F1</a>.</li>
                <li>Regulament tehnic: <a
                        href="https://www.fia.com/regulations#technical-rules">https://www.fia.com/regulations<wbr>#technical-rules</a>.
                </li>
                <li>Vizualizează produsul vedetă:
                    <a href="/imagini/tricou.jpg">
                        <img src="/imagini/favicon/favicon-96x96.png" alt="Miniatura produs"
                            style="width:40px;">
                    </a>
                </li>

                <li>Descarcă oferta curentă: <a href="/imagini/tricou2.jpg"
                        download="Oferta_Apex_Gear.jpg">Imagine Oferta (Download)</a></li>

            </ul>
        </section>

        <!--task bonus 1 formula-->
        <section id="fizica-tehnica">
            <h3>Fizica Performanței</h3>
            <p>Calculul forței necesare pentru a menține mașina pe trasă în viraje:</p>

            <math xmlns="http://www.w3.org/1998/Math/MathML" display="block" id="math-bonus">
                <msub>
                    <mi class="math-accent">F</mi>
                    <mi>c</mi>
                </msub>
                <mo>=</mo>
                <mfrac>
                    <mrow>
                        <mi>m</mi>
                        <mo>⋅</mo>
                        <msup>
                            <mi class="math-highlight">v</mi>
                            <mn>2</mn>
                        </msup>
                    </mrow>
                    <mi>r</mi>
                </mfrac>
            </math>

            <ul>
                <li><strong>m</strong> - masa monopostului</li>
                <li><strong>v</strong> - viteza de rulare</li>
                <li><strong>r</strong> - raza virajului</li>
            </ul>
        </section>


    </main>
