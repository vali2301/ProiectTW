                <img src="<%= locals.infoEroare.imagine %>" alt="Imagine Eroare" style="max-width: 400px;">
            <% } %>
            
            <p><a href="/index">Înapoi la pagina principală</a></p>
        </section>
    </main>

    <%- include("../fragmente/footer.ejs") %>
</body>
</html>