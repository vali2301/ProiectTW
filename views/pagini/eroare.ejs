<!DOCTYPE html>
<html lang="ro">
<head>
    <%- include("../fragmente/head.ejs") %>
    <title><%= locals.titlu %></title>
</head>
<body>
    <%- include("../fragmente/header.ejs") %>

    <main>
        <section>
            <h2><%= locals.infoEroare.titlu %></h2>
            <p><%= locals.infoEroare.text %></p>
            
